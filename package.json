{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "openrouter-model-list",
  "title": "OpenRouter Model List",
  "description": "Browse, search, and copy OpenRouter model IDs",
  "icon": "extension-icon.png",
  "author": "markbulling",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "list-models",
      "title": "List OpenRouter Models",
      "subtitle": "OpenRouter",
      "description": "Browse, search, and copy OpenRouter model IDs",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.17",
    "@raycast/utils": "^2.2.4"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
